{
	"name": "@stimulir/code-runtime-git",
	"version": "0.1.4",
	"description": "Stimulir's git derivative. Re-exports the @rivet-dev/agent-os-git WASM software package descriptor + adds typed JS helpers (clone, commit, diff, status, branch) that wrap the underlying `git` command so adapters don't shell out manually.",
	"type": "module",
	"license": "Apache-2.0",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"scripts": { "build": "tsc", "check-types": "tsc --noEmit" },
	"dependencies": {
		"@rivet-dev/agent-os-git": "workspace:*",
		"@rivet-dev/agent-os-registry-types": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"typescript": "^5.7.2"
	},
	"publishConfig": { "registry": "https://npm.pkg.github.com" },
	"repository": { "type": "git", "url": "git+https://github.com/stimulir/code-runtime.git" }
}
